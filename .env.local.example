# ===========================================
# TrailView Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
#
# SUPABASE:
# 1. Go to https://supabase.com and create a free project
# 2. Go to Settings > API to find these values
# 3. Run supabase-schema.sql in the SQL Editor
#
# RLS (Row Level Security) is enabled on all tables:
#   - The anon key has read-only access to trails and regions
#   - Authenticated users can write (insert/update) to all tables
#   - See supabase-rls.sql for the full policy definitions
#
# MAPBOX:
# 1. Go to https://mapbox.com and create a free account
# 2. Copy your default public token from the Tokens page
#
# CLOUDFLARE (for Cloudflare Pages deployment):
# 1. Go to https://dash.cloudflare.com and create an account
# 2. Create an R2 bucket:  npx wrangler r2 bucket create trailview-assets
# 3. Create a KV namespace: npx wrangler kv namespace create TRAIL_CACHE
# 4. Paste the KV namespace ID into wrangler.toml
# 5. For CI/CD, add CLOUDFLARE_API_TOKEN and CLOUDFLARE_ACCOUNT_ID to GitHub Secrets

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token-here

# Admin access: create a user in your Supabase project (Authentication > Users)
# and sign in with those credentials at /admin. No env var needed.

# Supabase JWT Secret — used by Cloudflare Pages Functions to verify JWT signatures.
# Find it in Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Set to "cloudflare" when building for Cloudflare Pages (removes /trailview basePath)
# DEPLOY_TARGET=cloudflare
